{
  "manifest_version": 3,
  "name": "Color PickUp",
  "version": "3.0",
  "description": "An elegant color picker and palette explorer for developers and designers.",
  "homepage_url": "https://Pro-Bandey.github.io/?id==Color-PickUp",

  "offline_enabled": true,

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "64": "icons/64.png",
    "128": "icons/128.png"
  },

  "action": {
    "default_popup": "page/index.html",
    "default_title": "Color PickUp",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "64": "icons/64.png"
    }
  },

  "permissions": ["storage", "contextMenus"],

  "background": {
    "service_worker": "background.js"
  }
}
