{
  "manifest_version": 3,
  "name": "Color PickUp",
  "version": "3.0",
  "description": "An elegant color picker and palette explorer for developers and designers.",
  "homepage_url": "https://Pro-Bandey.github.io/?id==Color-PickUp",

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "64": "icons/64.png",
    "128": "icons/128.png"
  },

  "action": {
    "default_popup": "page/index.html",
    "default_title": "Color PickUp",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "64": "icons/64.png"
    }
  },

  "permissions": ["storage", "contextMenus"],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "color-pickup@pro-bandey.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
